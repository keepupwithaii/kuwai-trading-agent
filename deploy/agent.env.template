# /etc/kuwai/agent.env -- ROOT-ONLY chmod 600. Pasted by the operator on the
# VPS. Never committed. systemd EnvironmentFile injects these into the unit.
# Leave KUWAI_MODE=paper until Maran's explicit go-live per-step trigger.

KUWAI_MODE=paper

# Alpaca PAPER (paper-api.alpaca.markets). Fill from
# /Users/maraneweda/config/Alpaca/token (paper).rtf
APCA_PAPER_KEY_ID=
APCA_PAPER_SECRET=

# Alpaca LIVE (api.alpaca.markets). Account 258088643. Only used when
# KUWAI_MODE=live, set ONLY by Maran's go-live step.
APCA_LIVE_KEY_ID=
APCA_LIVE_SECRET=

# Anthropic API. From /Users/maraneweda/config/Anthropic/API.rtf
ANTHROPIC_API_KEY=

# Apify token for Block N (live runtime only). From
# /Users/maraneweda/config/Apify/token (or token.rtf). Empty is fine until
# the Block-N named list is populated by Maran.
APIFY_TOKEN=

# Synthetic E0 for the paper cycle ONLY. The REAL E0 is captured at the
# Maran-triggered seal step from the live account; this placeholder is
# overwritten at that step. Until then, set this to the paper account
# starting equity for the cycle to evaluate the floor predicate.
KUWAI_E0=200.0

# The published seal hash; checked by ExecStartPre. Filled at the seal step.
# Leave blank during the paper cycle; the unit's ExecStartPre check is then
# satisfied by manual override (KUWAI_SKIP_SEAL_CHECK=1 in paper mode).
SEAL_EXPECTED_HASH=
KUWAI_SKIP_SEAL_CHECK=1

# Healthchecks.io ping URL (free tier). Create one and paste here. The
# watchdog pings on heartbeat, /fail on silent-dead.
HEALTHCHECKS_PING_URL=

# Ledger location on the VPS. systemd ReadWritePaths matches.
KUWAI_LEDGER=/var/lib/kuwai/ledger.log
