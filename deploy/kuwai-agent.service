# /etc/systemd/system/kuwai-agent.service
# Deployable artefact (27 §3.2). Not executed by the build. Oneshot; the
# timer is the restart. ExecStartPre fails loud on dead auth / wrong clock /
# seal-hash mismatch (the amendment loader's ExecStartPre hash-check). Secrets
# come ONLY from the root-only EnvironmentFile (chmod 600), never the repo.
[Unit]
Description=KUWAI commitment-v2 sealed autonomous trading agent (one wake)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=kuwai
Environment=PYTHONDONTWRITEBYTECODE=1
EnvironmentFile=/etc/kuwai/agent.env
# 1) refuse to start unless the on-disk sealed tree hash matches the published
#    seal (the expected hash is provisioned at deploy from the published
#    Release; it is NOT pre-registered by the build, pause point (b)).
ExecStartPre=/usr/bin/python3 -B /opt/kuwai/commitment-v2/code/amendment_loader.py ${SEAL_EXPECTED_HASH}
# 2) auth + clock preflight (fail loud, fail early; 27 §1.3 / §3.2).
ExecStartPre=/usr/bin/python3 -B /opt/kuwai/run_agent.py --check-auth --check-clock
ExecStart=/usr/bin/python3 -B /opt/kuwai/run_agent.py
TimeoutStartSec=300
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/kuwai
PrivateTmp=true

[Install]
WantedBy=multi-user.target
